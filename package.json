{
  "name": "arsenal-design",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.9.0",
  "description": "Arsenal Design, A high quality Vue 3 components library",
  "author": {
    "name": "Tong Siyuan"
  },
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./types/components/index.d.ts",
      "import": "./es/index.mjs",
      "require": "./lib/index.js"
    },
    "./es": {
      "types": "./types/components/index.d.ts",
      "import": "./es/index.mjs"
    },
    "./lib": {
      "types": "./types/components/index.d.ts",
      "require": "./lib/index.cjs"
    },
    "./es/*.mjs": {
      "types": "./types/components/*.d.ts",
      "import": "./es/*.mjs"
    },
    "./es/*": {
      "types": [
        "./types/components/*.d.ts",
        "./types/components/*/index.d.ts"
      ],
      "import": "./es/*.mjs"
    },
    "./lib/*.cjs": {
      "types": "./types/components/*.d.ts",
      "require": "./lib/*.cjs"
    },
    "./lib/*": {
      "types": [
        "./types/components/*.d.ts",
        "./types/components/*/index.d.ts"
      ],
      "require": "./lib/*.cjs"
    },
    "./package.json": "./package.json",
    "./*": "./*"
  },
  "main": "lib/index.js",
  "module": "es/index.mjs",
  "workspaces": [
    "docs",
    "dev-serve"
  ],
  "scripts": {
    "test": "vitest",
    "publish": "tsx scripts/publish.ts",
    "serve": "tsx scripts/serve.ts",
    "lint:style": "stylelint --cache \"**/*.{vue,scss}\"",
    "lint:style:fix": "stylelint --cache \"**/*.{vue,scss}\" --fix",
    "serve:docs": "pnpm -C docs serve",
    "bootstrap": "tsx scripts/bootstrap.ts",
    "bootstrap:icons": "tsx scripts/geneIcon.ts",
    "create": "tsx scripts/create.ts",
    "lint": "eslint . --fix",
    "build": "tsx ./scripts/build.ts",
    "build:meta": "tsx ./scripts/meta.ts",
    "build:style": "gulp",
    "build:icons": "pnpm -C common/icons build",
    "build:hooks": "pnpm -C packages/hooks build",
    "build:internal": "pnpm -C packages/internal build",
    "build-all": "run-s build-common build",
    "build-common": "run-s build:internal build:hooks build:icons",
    "precommit": "lint-staged -c ./.husky/.lintstagedrc --no-stash --allow-empty",
    "prepare": "husky ./.husky"
  },
  "peerDependencies": {
    "vue": "^3.2.0"
  },
  "dependencies": {
    "@arsenal-design/common": "workspace:*",
    "@arsenal-design/hooks": "workspace:*",
    "dayjs": "^1.11.3",
    "tsx": "^4.21.0",
    "yup": "^1.3.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^2.14.0",
    "@arsenal-design/icons": "workspace:*",
    "@types/fs-extra": "^11.0.4",
    "@types/gulp": "^4.0.18",
    "@types/gulp-autoprefixer": "^0.0.37",
    "@types/gulp-clean-css": "^4.3.4",
    "@types/gulp-sass": "^6.0.0",
    "@types/minimist": "^1.2.5",
    "@types/prompts": "^2.4.9",
    "@vexip-ui/stylelint-config": "^1.1.0",
    "@vitejs/plugin-vue": "^4.1.0",
    "@vitejs/plugin-vue-jsx": "^3.0.1",
    "execa": "^8",
    "fast-glob": "^3.2.12",
    "fs-extra": "^11.3.2",
    "gulp": "^5.0.1",
    "gulp-autoprefixer": "^10.0.0",
    "gulp-clean-css": "^4.3.0",
    "gulp-sass": "^6.0.1",
    "husky": "^9.1.7",
    "kolorist": "^1.8.0",
    "lint-staged": "^15.2.2",
    "minimist": "^1.2.8",
    "prettier": "^3.7.4",
    "prompts": "^2.4.2",
    "stylelint": "^17.0.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-prettier": "^5.0.3",
    "sucrase": "^3.35.1",
    "typescript": "5.4.4",
    "unplugin-vue-define-options": "^1.3.7",
    "vite": "^6.4.1",
    "vite-plugin-dts": "^3.5.4"
  }
}
